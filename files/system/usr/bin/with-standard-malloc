set -euo pipefail

usage() {
    echo 'Usage: with-standard-malloc COMMAND [ARGS...]'
    echo 'Runs COMMAND with the standard memory allocator instead of hardened_malloc.'
    exit
}

case "${1-}" in
    ''|--help) usage ;;
    --) shift ;;
    *) ;;
esac

LD_PRELOAD='' exec -- "$@"
