HOME_DIR/\.config			gen_context(system_u:object_r:config_home_t,s0)
HOME_DIR/\.config/.+			gen_context(system_u:object_r:config_contents_home_t,s0)
/root/\.config				gen_context(system_u:object_r:config_home_t,s0)
/root/\.config/.+			gen_context(system_u:object_r:config_contents_home_t,s0)

HOME_DIR/\.cache/dconf			gen_context(system_u:object_r:dconf_config_home_t,s0)
HOME_DIR/\.cache/dconf/.+		gen_context(system_u:object_r:dconf_config_home_t,s0)
/root/\.cache/dconf			gen_context(system_u:object_r:dconf_config_home_t,s0)
/root/\.cache/dconf/.+			gen_context(system_u:object_r:dconf_config_home_t,s0)
/run/user/%{USERID}/dconf		gen_context(system_u:object_r:dconf_config_home_t,s0)
/run/user/%{USERID}/dconf/.+		gen_context(system_u:object_r:dconf_config_home_t,s0)

HOME_DIR/\.kde				gen_context(system_u:object_r:kde_config_home_t,s0)
