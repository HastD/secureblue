/root/\.kde				gen_context(system_u:object_r:kde_config_home_t,s0)
/root/\.kde/.+				gen_context(system_u:object_r:kde_config_home_t,s0)

HOME_DIR/\.xine				gen_context(system_u:object_r:xine_config_home_t,s0)
